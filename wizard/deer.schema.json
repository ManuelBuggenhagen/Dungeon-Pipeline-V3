{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dungeon.local/schemas/deer.schema.json",
  "title": "DEER Authoring Configuration",
  "description": "First draft schema for the editable wizard authoring file. Semantic cross-reference checks remain part of the generator validator.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "formatVersion",
    "metadata",
    "session",
    "scenario",
    "surfaces",
    "riddleGraph",
    "riddles",
    "assets"
  ],
  "properties": {
    "formatVersion": {
      "const": "0.1-draft"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "session": {
      "$ref": "#/$defs/session"
    },
    "scenario": {
      "$ref": "#/$defs/scenario"
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface"
      }
    },
    "riddleGraph": {
      "$ref": "#/$defs/riddleGraph"
    },
    "riddles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/riddle"
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/asset"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "token": {
      "type": "string",
      "pattern": "^token_[a-z0-9_]+$"
    },
    "tokenArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/token"
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "locale"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "locale": {
          "type": "string",
          "minLength": 2
        },
        "description": {
          "type": "string"
        },
        "author": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetAudience",
        "priorKnowledge",
        "playerCount",
        "time"
      ],
      "properties": {
        "targetAudience": {
          "type": "string",
          "minLength": 1
        },
        "priorKnowledge": {
          "type": "string"
        },
        "playerCount": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "min",
            "max"
          ],
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 1
            },
            "max": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "time": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "limitMinutes",
            "limitMode"
          ],
          "properties": {
            "limitMinutes": {
              "type": "integer",
              "minimum": 1
            },
            "limitMode": {
              "enum": [
                "hard",
                "soft"
              ]
            }
          }
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "themeId",
        "playerRole",
        "premise",
        "mission",
        "introText",
        "successText",
        "failureText"
      ],
      "properties": {
        "themeId": {
          "const": "default"
        },
        "playerRole": {
          "type": "string",
          "minLength": 1
        },
        "premise": {
          "type": "string",
          "minLength": 1
        },
        "mission": {
          "type": "string",
          "minLength": 1
        },
        "introText": {
          "type": "string",
          "minLength": 1
        },
        "successText": {
          "type": "string",
          "minLength": 1
        },
        "failureText": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "title"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "enum": [
            "world",
            "world_object",
            "computer",
            "keypad",
            "door",
            "container",
            "inventory",
            "control_panel",
            "assembly_area"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "generatedFromRiddleIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        }
      }
    },
    "riddleGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startNodeId",
        "endNodeIds",
        "nodes",
        "edges"
      ],
      "properties": {
        "startNodeId": {
          "$ref": "#/$defs/id"
        },
        "endNodeIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "nodes": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/graphNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graphEdge"
          }
        }
      }
    },
    "graphNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "title"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "enum": [
            "start",
            "riddle",
            "event",
            "end"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "riddleId": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "graphEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "from",
        "to",
        "condition"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "from": {
          "$ref": "#/$defs/id"
        },
        "to": {
          "$ref": "#/$defs/id"
        },
        "condition": {
          "$ref": "#/$defs/edgeCondition"
        }
      }
    },
    "edgeCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "always",
            "all_of_tokens",
            "any_of_tokens"
          ]
        },
        "tokens": {
          "$ref": "#/$defs/tokenArray"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "always"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "not": {
              "required": [
                "tokens"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "all_of_tokens",
                  "any_of_tokens"
                ]
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "tokens"
            ],
            "properties": {
              "tokens": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "riddle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "title",
        "designRole",
        "difficulty",
        "estimatedMinutes",
        "playerFacingTask",
        "requiresTokens",
        "producesTokens",
        "assetIds",
        "resources",
        "hints",
        "parameters"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "enum": [
            "collection",
            "input",
            "choice",
            "item_use",
            "assembly",
            "state_change",
            "control_panel"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "designRole": {
          "enum": [
            "progression",
            "clue",
            "story",
            "support"
          ]
        },
        "difficulty": {
          "enum": [
            "easy",
            "medium",
            "hard"
          ]
        },
        "estimatedMinutes": {
          "type": "integer",
          "minimum": 1
        },
        "playerFacingTask": {
          "type": "string",
          "minLength": 1
        },
        "requiresTokens": {
          "$ref": "#/$defs/tokenArray"
        },
        "producesTokens": {
          "$ref": "#/$defs/tokenArray"
        },
        "assetIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "resources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resource"
          }
        },
        "hints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hint"
          }
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "successEffect": {
              "$ref": "#/$defs/successEffect"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "input"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "parameters": {
                "required": [
                  "inputMode"
                ],
                "properties": {
                  "inputMode": {
                    "enum": [
                      "numeric",
                      "text",
                      "credentials",
                      "decoded_text"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "choice"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "parameters": {
                "required": [
                  "selectionMode",
                  "options"
                ],
                "properties": {
                  "selectionMode": {
                    "enum": [
                      "single_correct",
                      "multiple_correct",
                      "classification"
                    ]
                  },
                  "options": {
                    "type": "array",
                    "minItems": 2
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "control_panel"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "parameters": {
                "required": [
                  "controls",
                  "completionState"
                ],
                "properties": {
                  "controls": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "$ref": "#/$defs/control"
                    }
                  },
                  "completionState": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      ]
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "title",
        "availability",
        "purpose"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "enum": [
            "inline_text",
            "asset",
            "world_object",
            "computer_file"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "assetId": {
          "$ref": "#/$defs/id"
        },
        "text": {
          "type": "string"
        },
        "availability": {
          "enum": [
            "visible_in_level",
            "inside_container",
            "after_token",
            "generated_by_riddle"
          ]
        },
        "requiredToken": {
          "$ref": "#/$defs/token"
        },
        "purpose": {
          "enum": [
            "clue",
            "context",
            "instruction",
            "decoy"
          ]
        }
      },
      "not": {
        "anyOf": [
          {
            "required": [
              "producesToken"
            ]
          },
          {
            "required": [
              "producesTokens"
            ]
          }
        ]
      }
    },
    "hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "text",
        "severity"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "integer",
          "minimum": 1
        },
        "unlock": {
          "$ref": "#/$defs/hintUnlock"
        }
      }
    },
    "hintUnlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator",
        "conditions"
      ],
      "properties": {
        "operator": {
          "enum": [
            "all_of",
            "any_of"
          ]
        },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/hintUnlockCondition"
          }
        }
      }
    },
    "hintUnlockCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "elapsed_time",
            "failed_attempts",
            "resource_viewed",
            "surface_visited",
            "riddle_completed",
            "token_available"
          ]
        },
        "seconds": {
          "type": "integer",
          "minimum": 1
        },
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "riddleId": {
          "$ref": "#/$defs/id"
        },
        "resourceId": {
          "$ref": "#/$defs/id"
        },
        "surfaceId": {
          "$ref": "#/$defs/id"
        },
        "token": {
          "$ref": "#/$defs/token"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "elapsed_time"
              }
            }
          },
          "then": {
            "required": [
              "seconds"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "failed_attempts"
              }
            }
          },
          "then": {
            "required": [
              "riddleId",
              "count"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "resource_viewed"
              }
            }
          },
          "then": {
            "required": [
              "resourceId"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "surface_visited"
              }
            }
          },
          "then": {
            "required": [
              "surfaceId"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "riddle_completed"
              }
            }
          },
          "then": {
            "required": [
              "riddleId"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "token_available"
              }
            }
          },
          "then": {
            "required": [
              "token"
            ]
          }
        }
      ]
    },
    "control": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "enum": [
            "button",
            "toggle",
            "text_input",
            "password_input"
          ]
        },
        "requiresStates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "setsState": {
          "type": "string"
        }
      },
      "not": {
        "anyOf": [
          {
            "required": [
              "producesToken"
            ]
          },
          {
            "required": [
              "producesTokens"
            ]
          }
        ]
      }
    },
    "successEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "set_state",
            "grant_resources",
            "grant_items",
            "unlock_surface",
            "open_surface",
            "mount_item",
            "spawn_content",
            "reveal_resource"
          ]
        },
        "stateId": {
          "$ref": "#/$defs/id"
        },
        "resourceId": {
          "$ref": "#/$defs/id"
        },
        "resourceIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "itemId": {
          "$ref": "#/$defs/id"
        },
        "itemIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "surfaceId": {
          "$ref": "#/$defs/id"
        },
        "targetSurfaceId": {
          "$ref": "#/$defs/id"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "set_state"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "stateId"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "grant_resources"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "resourceIds"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "grant_items"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "itemIds"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "unlock_surface",
                  "open_surface"
                ]
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "surfaceId"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "mount_item"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "itemId",
              "targetSurfaceId"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "spawn_content"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "anyOf": [
              {
                "required": [
                  "resourceId"
                ]
              },
              {
                "required": [
                  "surfaceId"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "reveal_resource"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "resourceId"
            ]
          }
        }
      ]
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "mediaType",
        "purpose",
        "linkedTo",
        "required",
        "source"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "path": {
          "type": "string",
          "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\.\\.).+"
        },
        "mediaType": {
          "enum": [
            "image/png",
            "image/jpeg",
            "audio/wav",
            "audio/mp3",
            "audio/ogg",
            "text/plain"
          ]
        },
        "purpose": {
          "enum": [
            "riddle_evidence",
            "lore",
            "feedback",
            "decorative",
            "audio_cue"
          ]
        },
        "linkedTo": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "required": {
          "type": "boolean"
        },
        "source": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "type",
            "license"
          ],
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "license": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
